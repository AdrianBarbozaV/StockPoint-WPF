<UserControl x:Class="StockPoint.WPF.Views.OrdenUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StockPoint.WPF.Views"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="950">

    <Grid Margin="20,20,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <Label Grid.Row="0" Content="Registrar Orden de Trabajo"
               FontSize="16" FontStyle="Oblique"
               HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- MAESTRO: cliente y fecha -->
        <GroupBox Header="Orden" Grid.Row="1" Margin="0,0,0,10">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Content="Cliente:" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" Margin="4,0,20,0"
                          ItemsSource="{Binding Clientes}"
                          SelectedItem="{Binding ClienteSeleccionado, Mode=TwoWay}"
                          DisplayMemberPath="Nombre"/>

                <Label Grid.Column="2" Content="Fecha:" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Margin="4,0,0,0" VerticalAlignment="Center"
                           Text="{Binding FechaOrden, StringFormat=dd/MM/yyyy}"/>
            </Grid>
        </GroupBox>

        <!-- Búsqueda de producto -->
        <GroupBox Header="Agregar Producto" Grid.Row="2" Margin="0,0,0,10">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Content="Buscar:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Margin="4,0,8,0" VerticalAlignment="Center"
                         Text="{Binding BusquedaProducto, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="2" Content="Buscar" Padding="10,4" Margin="0,0,16,0"
                        Command="{Binding BuscarProductoCommand}"/>

                <ComboBox Grid.Column="3" Margin="0,0,8,0"
                          ItemsSource="{Binding ResultadosBusqueda}"
                          SelectedItem="{Binding ProductoSeleccionado, Mode=TwoWay}"
                          DisplayMemberPath="Nombre"/>
                <Button Grid.Column="4" Content="Agregar" Padding="10,4"
                        Command="{Binding AgregarProductoCommand}"/>
            </Grid>
        </GroupBox>

        <!-- DETALLE: matriz maestro-detalle -->
        <DataGrid Grid.Row="3" Margin="0,0,0,10"
                  ItemsSource="{Binding Detalles}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  HorizontalAlignment="Stretch">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código"       Binding="{Binding Codigo}"          Width="90"  IsReadOnly="True"/>
                <DataGridTextColumn Header="Producto"     Binding="{Binding NombreProducto}"  Width="*"   IsReadOnly="True"/>
                <DataGridTextColumn Header="Precio Unit." Binding="{Binding PrecioUnitario, StringFormat=C2}" Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="Cantidad"     Binding="{Binding Cantidad}"        Width="80"  IsReadOnly="True"/>
                <DataGridTextColumn Header="Subtotal"     Binding="{Binding Subtotal, StringFormat=C2}"       Width="110" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Acciones" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="+" Width="30" Margin="2,0"
                                        Command="{Binding DataContext.IncrementarCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="−" Width="30" Margin="2,0"
                                        Command="{Binding DataContext.DecrementarCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="✕" Width="30" Margin="2,0" Foreground="Red"
                                        Command="{Binding DataContext.RemoverCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Totales + Procesar -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Right" Margin="0,0,24,0">
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Impuesto de venta:" Width="160" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalImpuesto, StringFormat=C2}" Width="100" TextAlignment="Right"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Total:" Width="160" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding TotalVenta, StringFormat=C2}" Width="100"
                               TextAlignment="Right" FontWeight="Bold" FontSize="14"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1" Content="Procesar Orden" Padding="20,10"
                    FontSize="13" FontWeight="SemiBold"
                    Command="{Binding ProcesarOrdenCommand}"/>
        </Grid>
    </Grid>
</UserControl>
