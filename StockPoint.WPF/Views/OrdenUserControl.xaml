<UserControl x:Class="StockPoint.WPF.Views.OrdenUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.DataContext>
        <vm:OrdenViewModel xmlns:vm="clr-namespace:StockPoint.WPF.ViewModels"/>
    </UserControl.DataContext>

    <UserControl.Resources>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LightInput" TargetType="TextBox">
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,14,0,5"/>
        </Style>

        <Style x:Key="LightCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="#1D4ED8"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LightRow" TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#374151"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnIcon" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#F1F5F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Cabecera de sección ══ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"
                Padding="18,11">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Orden de Trabajo"
                           Foreground="#111827" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock Text="Nueva venta · Clientes · Productos"
                           Foreground="#9CA3AF" FontSize="11" Margin="0,1,0,0"/>
            </StackPanel>
        </Border>

        <!-- ══ Contenido ══ -->
        <Grid Grid.Row="1" Margin="16,14,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ IZQUIERDA: formulario ═══ -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                    CornerRadius="4" Margin="0,0,12,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,18,22,24">

                        <!-- Cliente -->
                        <TextBlock Text="CLIENTE" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                        <ComboBox Background="White" Foreground="#111827"
                                  BorderBrush="#D1D5DB" BorderThickness="1"
                                  Padding="8,6" FontSize="13"
                                  ItemsSource="{Binding Clientes}"
                                  SelectedItem="{Binding ClienteSeleccionado, Mode=TwoWay}"
                                  DisplayMemberPath="Nombre"/>

                        <!-- Fecha -->
                        <TextBlock Text="FECHA DE ORDEN" Style="{StaticResource FieldLabel}"/>
                        <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1"
                                CornerRadius="4" Padding="9,8">
                            <TextBlock Text="{Binding FechaOrden, StringFormat=dd/MM/yyyy}"
                                       Foreground="#6B7280" FontSize="13"/>
                        </Border>

                        <!-- Buscar producto -->
                        <TextBlock Text="BUSCAR PRODUCTO" Style="{StaticResource FieldLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource LightInput}" Margin="0,0,8,0"
                                     Text="{Binding BusquedaProducto, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Buscar" Margin="0,0,8,0"
                                    Style="{StaticResource ActionButton}" Background="#2563EB"
                                    Command="{Binding BuscarProductoCommand}"/>
                            <ComboBox Grid.Column="2" Background="White" Foreground="#111827"
                                      BorderBrush="#D1D5DB" BorderThickness="1"
                                      Padding="8,6" FontSize="13" Margin="0,0,8,0"
                                      ItemsSource="{Binding ResultadosBusqueda}"
                                      SelectedItem="{Binding ProductoSeleccionado, Mode=TwoWay}"
                                      DisplayMemberPath="NombreEtiqueta"/>
                            <Button Grid.Column="3" Content="+ Agregar"
                                    Style="{StaticResource ActionButton}" Background="#1A7F37"
                                    Command="{Binding AgregarProductoCommand}"/>
                        </Grid>

                        <!-- Detalle -->
                        <TextBlock Text="DETALLE DE LA ORDEN" Style="{StaticResource FieldLabel}" Margin="0,20,0,8"/>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4">
                            <DataGrid ItemsSource="{Binding Detalles}"
                                      Background="White"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F9FAFB"
                                      Foreground="#374151"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#E5E7EB"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserResizeRows="False"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column"
                                      CellStyle="{StaticResource LightCell}"
                                      RowStyle="{StaticResource LightRow}">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F9FAFB"/>
                                        <Setter Property="Foreground" Value="#6B7280"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="CÓDIGO"       Binding="{Binding Codigo}"                                Width="85"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="NOMBRE"       Binding="{Binding NombreProducto}"                       Width="*"   IsReadOnly="True"/>
                                    <DataGridTextColumn Header="PRECIO UNIT." Binding="{Binding PrecioUnitario, StringFormat='₡{0:N0}'}" Width="110" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="CANT."        Binding="{Binding Cantidad}"                             Width="60"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="SUBTOTAL"     Binding="{Binding Subtotal, StringFormat='₡{0:N0}'}"     Width="105" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="IVA"          Binding="{Binding ImpuestoLinea, StringFormat='₡{0:N0}'}" Width="90" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Button Content="+" Style="{StaticResource BtnIcon}" Background="#2563EB" Margin="2,0"
                                                            Command="{Binding DataContext.IncrementarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="−" Style="{StaticResource BtnIcon}" Background="#9CA3AF" Margin="2,0"
                                                            Command="{Binding DataContext.DecrementarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="✕" Style="{StaticResource BtnIcon}" Background="#DC2626" Margin="2,0"
                                                            Command="{Binding DataContext.RemoverCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Notas -->
                        <TextBlock Text="NOTAS" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource LightInput}"
                                 Height="76" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Notas, UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═══ DERECHA: resumen ═══ -->
            <Border Grid.Column="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                    CornerRadius="4">
                <StackPanel Margin="20,22,20,22">

                    <TextBlock Text="Resumen de Orden"
                               Foreground="#111827" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <Rectangle Height="1" Fill="#E5E7EB" Margin="0,0,0,12"/>

                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Subtotal" Foreground="#6B7280" FontSize="13"/>
                        <TextBlock Grid.Column="1" Foreground="#374151" FontSize="13"
                                   Text="{Binding SubtotalSinImpuesto, StringFormat='₡{0:N0}'}"/>
                    </Grid>

                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="IVA (13%)" Foreground="#6B7280" FontSize="13"/>
                        <TextBlock Grid.Column="1" Foreground="#374151" FontSize="13"
                                   Text="{Binding TotalImpuesto, StringFormat='₡{0:N0}'}"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#E5E7EB" Margin="0,8,0,8"/>

                    <Grid Margin="0,4,0,24">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Total" Foreground="#111827" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Foreground="#111827" FontSize="16" FontWeight="Bold"
                                   Text="{Binding TotalVenta, StringFormat='₡{0:N0}'}"/>
                    </Grid>

                    <Button Content="Procesar Orden"
                            Style="{StaticResource ActionButton}"
                            Background="#1A7F37"
                            Padding="14,10"
                            FontSize="13"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8"
                            Command="{Binding ProcesarOrdenCommand}"/>

                    <Button Content="Cancelar"
                            Style="{StaticResource OutlineButton}"
                            HorizontalAlignment="Stretch"
                            Padding="14,10"/>

                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>
