<Window x:Class="StockPoint.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:StockPoint.WPF.Views"
        mc:Ignorable="d"
        Title="StockPoint" Height="740" Width="1020"
        WindowStartupLocation="CenterScreen"
        Background="#0f172a">

    <Window.Resources>

        <!-- TabItem oscuro con ControlTemplate mínimo -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#64748b"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#0ea5e9"/>
                                <Setter Property="Foreground" Value="#f1f5f9"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#cbd5e1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header de la app -->
        <Border Grid.Row="0" Background="#111827" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="StockPoint"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#f1f5f9" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1"
                    Background="#0f172a"
                    BorderThickness="0"
                    Padding="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Franja de tabs -->
                        <Border Grid.Row="0"
                                Background="#111827"
                                BorderBrush="#1e293b"
                                BorderThickness="0,0,0,1"
                                Padding="12,0">
                            <TabPanel IsItemsHost="True"/>
                        </Border>
                        <!-- Contenido del tab seleccionado -->
                        <ContentPresenter Grid.Row="1"
                                          ContentSource="SelectedContent"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <TabItem Header="Orden de Trabajo">
                <views:OrdenUserControl/>
            </TabItem>

            <TabItem Header="Gestión de Producto">
                <views:ProductoUserControl/>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
